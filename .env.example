NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgres://user:password@host:5432/neptune
ALLOW_DEMO_LOGIN=false
DEMO_ADMIN_EMAIL=
DEMO_ADMIN_PASSWORD=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CAPTAIN=
STRIPE_PRICE_FLEETOPS=
STRIPE_PRICE_ENTERPRISE=

# Open-Meteo weather, geocoding, and marine forecast services.
# Public endpoints work during development. Configure a commercial Open-Meteo account/base URLs for paid production usage when required.
OPEN_METEO_API_KEY=
OPEN_METEO_WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_MARINE_BASE_URL=https://marine-api.open-meteo.com/v1/marine
OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com/v1/search

# MarineTraffic/Kpler port congestion connection.
# URL supports placeholders: {portId}, {providerPortId}, {unlocode}, {latitude}, {longitude}
MARINETRAFFIC_API_KEY=
MARINETRAFFIC_PORT_CONGESTION_URL=

# Optional live bunker price provider.
# URL supports placeholders: {port}, {fuelType}
BUNKER_PRICE_PROVIDER_NAME=
BUNKER_PRICE_API_KEY=
BUNKER_PRICE_API_URL=
